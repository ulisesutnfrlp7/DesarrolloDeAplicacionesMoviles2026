rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    function isProfesor() {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'profesor';
    }

    function validSubseccionAccessCode() {
      let ids = request.resource.data.subseccionIds;
      return ids is list
        && ids.size() > 0
        && ids.size() <= 6
        && (
          (ids.size() == 1 &&
            get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId)/subsecciones/$(ids[0])).data.codigoAcceso == request.resource.data.codigoUsado) ||
          (ids.size() == 2 &&
            get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId)/subsecciones/$(ids[0])/subsecciones/$(ids[1])).data.codigoAcceso == request.resource.data.codigoUsado) ||
          (ids.size() == 3 &&
            get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId)/subsecciones/$(ids[0])/subsecciones/$(ids[1])/subsecciones/$(ids[2])).data.codigoAcceso == request.resource.data.codigoUsado) ||
          (ids.size() == 4 &&
            get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId)/subsecciones/$(ids[0])/subsecciones/$(ids[1])/subsecciones/$(ids[2])/subsecciones/$(ids[3])).data.codigoAcceso == request.resource.data.codigoUsado) ||
          (ids.size() == 5 &&
            get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId)/subsecciones/$(ids[0])/subsecciones/$(ids[1])/subsecciones/$(ids[2])/subsecciones/$(ids[3])/subsecciones/$(ids[4])).data.codigoAcceso == request.resource.data.codigoUsado) ||
          (ids.size() == 6 &&
            get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId)/subsecciones/$(ids[0])/subsecciones/$(ids[1])/subsecciones/$(ids[2])/subsecciones/$(ids[3])/subsecciones/$(ids[4])/subsecciones/$(ids[5])).data.codigoAcceso == request.resource.data.codigoUsado)
        );
    }

    // 1. Usuarios
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read, update, delete: if isAdmin();
    }

    // 2. Módulos y Secciones
    match /modulos/{moduloId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();

      match /secciones/{seccionId} {
        allow read: if request.auth != null;
        allow create, update, delete: if isAdmin();
      }
    }

    // Permite al panel admin consultar secciones con collectionGroup("secciones").
    match /{path=**}/secciones/{seccionId} {
      allow read: if isAdmin();
    }

    // 3. Subsecciones (Aplanado: funciona en cualquier nivel)
    match /{path=**}/subsecciones/{subseccionId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // 4. Items (Aplanado: funciona en cualquier nivel)
    match /{path=**}/items/{itemId} {
      allow read: if request.auth != null;
      // Confiamos en el frontend para la lógica de carpetas; validamos seguridad de autor acá
      allow create: if isAdmin() || (isProfesor() && request.resource.data.creadoPor == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // 5. Entregas Alumnos (Aplanado: funciona en cualquier nivel)
    match /{path=**}/entregas_alumnos/{entregaId} {
      allow read: if request.auth != null &&
        (isAdmin() || isProfesor() || (resource != null && resource.data.alumnoId == request.auth.uid));

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.alumnoId;

      allow update: if request.auth != null &&
        (
          isAdmin() || isProfesor() ||
          (resource != null && resource.data.alumnoId == request.auth.uid && request.resource.data.alumnoId == request.auth.uid)
        );

      allow delete: if isAdmin() || isProfesor();
    }

    // 6. Inscripciones y Notas
    match /inscripciones/{inscripcionId} {
      allow read: if request.auth != null &&
        (isAdmin() || isProfesor() || (resource != null && resource.data.alumnoId == request.auth.uid));

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.alumnoId
        && request.resource.data.tipo == 'codigo'
        && (!('subseccionPath' in request.resource.data) || request.resource.data.subseccionPath == '')
        && get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId)).data.codigoAcceso == request.resource.data.codigoUsado;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.alumnoId
        && request.resource.data.tipo == 'codigo'
        && ('subseccionPath' in request.resource.data)
        && request.resource.data.subseccionPath is string
        && request.resource.data.subseccionPath != ''
        && request.resource.data.codigoUsado is string
        && ('subseccionIds' in request.resource.data)
        && validSubseccionAccessCode();

      allow create: if isAdmin() && request.resource.data.tipo == 'manual';
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /notas/{notaId} {
      allow read: if request.auth != null &&
        (isAdmin() || isProfesor() || (resource != null && resource.data.alumnoId == request.auth.uid));
      allow create, update: if isAdmin() || isProfesor();
      allow delete: if isAdmin();
    }

    // 7. Planillas de trabajos practicos
    match /planillas_tp/{planillaId} {
      allow read, create, update: if isAdmin() || isProfesor();
      allow delete: if isAdmin();

      match /filas/{filaId} {
        allow read, create, update, delete: if isAdmin() || isProfesor();
      }

      match /vistas_alumno/{alumnoId} {
        allow read: if isAdmin() || isProfesor() ||
          (request.auth != null && request.auth.uid == alumnoId);
        allow create, update, delete: if isAdmin() || isProfesor();
      }
    }

    match /{path=**}/vistas_alumno/{alumnoId} {
      allow read: if isAdmin() || isProfesor() ||
        (request.auth != null && request.auth.uid == alumnoId);
    }

    match /vistas_planillas_alumnos/{alumnoId}/planillas/{planillaId} {
      allow read: if isAdmin() || isProfesor() ||
        (request.auth != null && request.auth.uid == alumnoId);
      allow create, update, delete: if isAdmin() || isProfesor();
    }

    match /planillas_base_tp/{baseId} {
      allow read: if isAdmin() || isProfesor();
      allow create, update, delete: if isAdmin();
    }

    match /{path=**}/inscripciones/{inscripcionId} {
      allow read, write: if request.auth != null 
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers de rol — leen el documento del usuario autenticado
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    function isProfesor() {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'profesor';
    }

    // Colección 'usuarios': solo el propio usuario puede leer/escribir su documento
    match /usuarios/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, update, delete: if isAdmin();
    }

    // Colección 'modulos': lectura para todos los autenticados, escritura solo admin
    match /modulos/{moduloId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();

      // Subcollección 'secciones': lectura para todos, escritura para admin y profesor
      match /secciones/{seccionId} {
        allow read: if request.auth != null;
        allow create, update, delete: if isAdmin() || isProfesor();

        // Subcolección 'items': lectura para todos, escritura para admin y profesor.
        // El comodín recursivo permite items directos y también items dentro de subsecciones anidadas.
        match /{path=**}/items/{itemId} {
          allow read: if request.auth != null;
          allow create, update, delete: if isAdmin() || isProfesor();
        }

        // Subcolección 'subsecciones': lectura para todos, escritura para admin y profesor.
        // El comodín recursivo permite subsecciones en cualquier profundidad.
        match /{path=**}/subsecciones/{subseccionId} {
          allow read: if request.auth != null;
          allow create, update, delete: if isAdmin() || isProfesor();
        }
      }
    }

    // Colección 'inscripciones': gestión de matrículas por cursada
    match /inscripciones/{inscripcionId} {
      // El propio alumno o el admin pueden leer
      allow read: if request.auth != null &&
        (resource.data.alumnoId == request.auth.uid || isAdmin());

      // Auto-matriculación por código: el alumno crea la propia inscripción
      // y el código debe coincidir con el almacenado en la sección
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.alumnoId
        && request.resource.data.tipo == 'codigo'
        && get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId))
            .data.codigoAcceso == request.resource.data.codigoUsado;

      // Asignación manual y eliminación: solo admin
      allow create: if isAdmin() && request.resource.data.tipo == 'manual';
      allow delete: if isAdmin();

      // Las inscripciones son inmutables (el admin elimina y recrea si es necesario)
      allow update: if false;
    }
  }
}

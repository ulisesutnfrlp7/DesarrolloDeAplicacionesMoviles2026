rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    function isProfesor() {
      return request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'profesor';
    }

    // 1. Usuarios
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read, update, delete: if isAdmin();
    }

    // 2. Módulos y Secciones
    match /modulos/{moduloId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();

      match /secciones/{seccionId} {
        allow read: if request.auth != null;
        allow create, update, delete: if isAdmin();
      }
    }

    // 3. Subsecciones (Aplanado: funciona en cualquier nivel)
    match /{path=**}/subsecciones/{subseccionId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // 4. Items (Aplanado: funciona en cualquier nivel)
    match /{path=**}/items/{itemId} {
      allow read: if request.auth != null;
      // Confiamos en el frontend para la lógica de carpetas; validamos seguridad de autor acá
      allow create: if isAdmin() || (isProfesor() && request.resource.data.creadoPor == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // 5. Entregas Alumnos (Aplanado: funciona en cualquier nivel)
    match /{path=**}/entregas_alumnos/{entregaId} {
      allow read: if request.auth != null &&
        (isAdmin() || isProfesor() || (resource != null && resource.data.alumnoId == request.auth.uid));

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.alumnoId;

      allow update: if request.auth != null &&
        (
          isAdmin() || isProfesor() ||
          (resource != null && resource.data.alumnoId == request.auth.uid && request.resource.data.alumnoId == request.auth.uid)
        );

      allow delete: if isAdmin() || isProfesor();
    }

    // 6. Inscripciones y Notas
    match /inscripciones/{inscripcionId} {
      allow read: if request.auth != null &&
        (isAdmin() || isProfesor() || (resource != null && resource.data.alumnoId == request.auth.uid));

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.alumnoId
        && request.resource.data.tipo == 'codigo'
        && get(/databases/$(database)/documents/modulos/$(request.resource.data.moduloId)/secciones/$(request.resource.data.seccionId)).data.codigoAcceso == request.resource.data.codigoUsado;

      allow create: if isAdmin() && request.resource.data.tipo == 'manual';
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /notas/{notaId} {
      allow read: if request.auth != null &&
        (isAdmin() || isProfesor() || (resource != null && resource.data.alumnoId == request.auth.uid));
      allow create, update: if isAdmin() || isProfesor();
      allow delete: if isAdmin();
    }
  }
}